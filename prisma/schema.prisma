generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  USER
}

model User {
  id          String                 @id @default(cuid())
  email       String                 @unique
  password    String
  name        String?
  department  String?
  position    String?
  phone       String?
  role        Role                   @default(USER)
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  products    Product[]
  exhibitions DevExhibitionVisitor[]
  permission  UserPermission?
}

model UserPermission {
  id            String   @id @default(cuid())
  userId        String   @unique @map("user_id")
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productsView  Boolean  @default(true)  @map("products_view")
  productsEdit  Boolean  @default(false) @map("products_edit")
  partsView     Boolean  @default(true)  @map("parts_view")
  partsEdit     Boolean  @default(false) @map("parts_edit")
  devView       Boolean  @default(true)  @map("dev_view")
  devEdit       Boolean  @default(false) @map("dev_edit")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt      @map("updated_at")

  @@map("user_permissions")
}

model Product {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  parts       Part[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Part {
  id        String   @id @default(cuid())
  code      String
  name      String
  note      String?
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DevCompany {
  id              String                 @id @default(cuid())
  name            String
  nameKana        String?
  industry        String?
  status          String                 @default("登録のみ")
  postalCode      String?                @map("postal_code")
  address         String?
  phone           String?
  url             String?
  notes           String?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  primaryProjects DevProject[]           @relation("DevPrimaryCompany")
  projects        DevProjectCompany[]
  exhibitions     DevExhibitionContact[]
  contacts        DevCompanyContact[]
  types           DevCompanyType[]

  @@map("dev_companies")
}

model DevProject {
  id                String              @id @default(cuid())
  title             String
  status            String              @default("商談中")
  description       String?
  expectedOrderDate DateTime?
  notes             String?
  primaryCompanyId  String?
  primaryCompany    DevCompany?         @relation("DevPrimaryCompany", fields: [primaryCompanyId], references: [id])
  companies         DevProjectCompany[]
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@map("dev_projects")
}

model DevProjectCompany {
  id        String     @id @default(cuid())
  projectId String
  companyId String
  role      String?
  project   DevProject @relation(fields: [projectId], references: [id])
  company   DevCompany @relation(fields: [companyId], references: [id])
  createdAt DateTime   @default(now())

  @@unique([projectId, companyId])
  @@map("dev_project_companies")
}

model DevExhibition {
  id          String                 @id @default(cuid())
  name        String
  location    String?
  startDate   DateTime?
  endDate     DateTime?
  notes       String?
  summary     String?
  description String?
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  visitors    DevExhibitionVisitor[]
  contacts    DevExhibitionContact[]

  @@map("dev_exhibitions")
}

model DevExhibitionVisitor {
  id           String        @id @default(cuid())
  exhibitionId String        @map("exhibition_id")
  userId       String        @map("user_id")
  impression   String?
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  exhibition   DevExhibition @relation(fields: [exhibitionId], references: [id], onDelete: Cascade)
  user         User          @relation(fields: [userId], references: [id])

  @@unique([exhibitionId, userId])
  @@map("dev_exhibition_visitors")
}

model DevExhibitionContact {
  id           String             @id @default(cuid())
  exhibitionId String             @map("exhibition_id")
  companyId    String             @map("company_id")
  contactId    String?            @map("contact_id")
  notes        String?
  createdAt    DateTime           @default(now()) @map("created_at")
  exhibition   DevExhibition      @relation(fields: [exhibitionId], references: [id], onDelete: Cascade)
  company      DevCompany         @relation(fields: [companyId], references: [id])
  contact      DevCompanyContact? @relation(fields: [contactId], references: [id])

  @@map("dev_exhibition_contacts")
}

model DevCompanyContact {
  id                 String                @id @default(cuid())
  companyId          String                @map("company_id")
  company            DevCompany            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name               String
  nameKana           String?               @map("name_kana")
  email              String?
  phone              String?
  department         String?
  position           String?
  isPrimary          Boolean               @default(false) @map("is_primary")
  notes              String?
  createdAt          DateTime              @default(now()) @map("created_at")
  updatedAt          DateTime              @updatedAt @map("updated_at")
  exhibitionContacts DevExhibitionContact[]

  @@map("dev_company_contacts")
}

model DevCompanyTypeMaster {
  id          String           @id @default(cuid())
  name        String           @unique
  description String?
  sortOrder   Int              @default(0) @map("sort_order")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  companies   DevCompanyType[]

  @@map("dev_company_type_masters")
}

model DevCompanyType {
  id           String               @id @default(cuid())
  companyId    String               @map("company_id")
  typeMasterId String               @map("type_master_id")
  company      DevCompany           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  typeMaster   DevCompanyTypeMaster @relation(fields: [typeMasterId], references: [id], onDelete: Cascade)
  createdAt    DateTime             @default(now()) @map("created_at")

  @@unique([companyId, typeMasterId])
  @@map("dev_company_types")
}
